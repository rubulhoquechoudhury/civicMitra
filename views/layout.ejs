<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Civic Mitra</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Report civic issues in your area. Your voice, your community." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="brand">
        <a href="/">Civic Mitra</a>
      </div>
      <nav>
        <% if (typeof user !== 'undefined' && user) { %>
        <span class="user-pill"><%= user.role === 'citizen' ? 'Citizen' : 'Authority' %>: <%= user.email %></span>
        <form method="POST" action="/logout" class="inline-form">
          <button type="submit" class="btn-secondary">Logout</button>
        </form>
        <% } else { %>
        <a href="/login" class="btn-link">Login</a>
        <a href="/signup" class="btn-primary">Sign up</a>
        <% } %>
      </nav>
    </header>
    <main class="container">
      <%- body %>
    </main>
    <footer class="footer">
      <span>Civic Mitra — Your voice, your community.</span>
    </footer>
  </body>
</html>

